# Copy this file to .env and fill in your real values.
# Never commit the actual .env file.

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=""

# APP_URL: The URL where this app is hosted.
APP_URL="http://localhost:3000"

# GOOGLE_CLIENT_ID: Your Google Cloud Console OAuth 2.0 Client ID.
GOOGLE_CLIENT_ID=""

# GOOGLE_CLIENT_SECRET: Your Google Cloud Console OAuth 2.0 Client Secret.
GOOGLE_CLIENT_SECRET=""

# SUPABASE_URL: Your Supabase Project URL (e.g., https://xyz.supabase.co).
SUPABASE_URL=""

# SUPABASE_KEY: Your Supabase Anon/Publishable Key (safe-ish for client use, still keep private in dev).
SUPABASE_KEY=""

# SUPABASE_SERVICE_ROLE_KEY: Your Supabase Service Role key.
# SERVER-SIDE ONLY. Bypasses Row Level Security. Never expose to the browser or commit this.
SUPABASE_SERVICE_ROLE_KEY=""
